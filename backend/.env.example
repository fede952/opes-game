# ==============================================================
# Opes Backend — Environment Variables Template
# ==============================================================
# HOW TO USE:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your actual values in .env
#   3. NEVER commit the .env file to version control (it's in .gitignore)
#
# This .env.example file is SAFE to commit — it contains only
# placeholder values, not real secrets. It serves as documentation
# for what environment variables the application needs to run.
# ==============================================================

# --- Server Configuration ---
PORT=3001
# Options: "development" | "production" | "test"
# In "development": detailed error messages, query logging, etc.
# In "production": generic error messages (no stack traces to clients), no debug logging.
NODE_ENV=development

# --- Frontend URL (for CORS in production) ---
# The URL of your deployed frontend. The API will only accept requests from this origin.
# Example: https://opes-game.com
FRONTEND_URL=http://localhost:3000

# --- PostgreSQL Database Configuration ---
# SECURITY: Treat DB_PASSWORD like a master key. Use a strong, randomly
# generated password in production (e.g., generated by a password manager).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=opes_db
DB_USER=postgres
DB_PASSWORD=your_strong_password_here

# Maximum number of simultaneous database connections in the pool.
# Increase this as your player base grows, but stay well below
# your PostgreSQL server's 'max_connections' limit (default: 100).
DB_MAX_CONNECTIONS=10

# --- JWT Authentication Secret ---
# SECURITY: This is the most critical secret in the entire application.
# It is used to SIGN every JWT token issued to players. Anyone who obtains
# this secret can forge tokens and impersonate any player — including admins.
#
# Rules for this value:
#   1. Generate it randomly. Do NOT use a memorable phrase or word.
#      Use a cryptographically secure generator:
#        Node.js:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#        OpenSSL:  openssl rand -hex 64
#   2. It must be at least 32 characters. 64+ is recommended.
#   3. NEVER commit it to version control. It lives ONLY in .env (which is gitignored).
#   4. Use a different secret for each environment (development, staging, production).
#      If the production secret is ever compromised, rotate it immediately —
#      all active player sessions will be invalidated (players must log in again).
JWT_SECRET=replace_this_with_a_long_random_string_minimum_32_characters
