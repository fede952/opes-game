# ============================================================
# DEPENDENCIES
# ============================================================
# The node_modules folder can contain hundreds of thousands of files.
# It must NEVER be committed to git — it's regenerated by 'npm install'.
node_modules/

# ============================================================
# ENVIRONMENT VARIABLES — MOST CRITICAL TO IGNORE
# ============================================================
# .env files contain secrets: database passwords, API keys, JWT secrets.
# Committing these to a public (or even private) repository is a severe
# security vulnerability. If you accidentally commit a .env file, you must
# treat all secrets it contained as compromised and rotate them immediately.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ============================================================
# BUILD OUTPUT
# ============================================================
# These are generated files — they should be produced by the CI/CD
# pipeline, not stored in version control.
dist/
build/

# TypeScript incremental compilation info files (generated by tsc)
*.tsbuildinfo

# ============================================================
# LOGS
# ============================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================
# OPERATING SYSTEM FILES
# ============================================================
# macOS metadata folders
.DS_Store
# Windows thumbnail cache
Thumbs.db

# ============================================================
# IDE / EDITOR FILES
# ============================================================
# These are personal editor settings — each developer may use different
# settings, so they should not be imposed on the whole team via git.
# Exception: if your team agrees on shared settings (e.g., ESLint config
# for a VS Code extension), you can remove that specific entry.
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
